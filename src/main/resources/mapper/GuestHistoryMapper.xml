<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="top.playereg.pix_vision.mapper.GuestHistoryMapper">

    <!-- 添加游客访问历史记录 -->
    <insert id="insertGuestHistory">
        INSERT INTO tb_guest_history (work_id, visit_time)
        VALUES (#{workId}, NOW())
    </insert>

    <!-- 统计指定作品的游客访问记录数（用于缓存回源） -->
    <select id="selectCountByWorkId" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM tb_guest_history
        WHERE work_id = #{workId}
    </select>

</mapper>
