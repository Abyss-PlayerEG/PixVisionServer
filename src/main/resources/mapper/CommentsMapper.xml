<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="top.playereg.pix_vision.mapper.CommentsMapper">

    <!-- 定义结果映射 -->
    <resultMap id="BaseResultMap" type="top.playereg.pix_vision.pojo.commentsPojo.Comments">
        <id column="comment_id" property="comment_id"/>
        <result column="user_id" property="user_id"/>
        <result column="work_id" property="work_id"/>
        <result column="parent_comment_id" property="parent_comment_id"/>
        <result column="in_comment_id" property="in_comment_id"/>
        <result column="comment_floor" property="comment_floor"/>
        <result column="comment_text" property="comment_text"/>
        <result column="approval_status" property="approval_status"/>
        <result column="is_delete" property="is_delete"/>
        <result column="time" property="time"/>
    </resultMap>

    <!-- 定义基础字段列表 -->
    <sql id="Base_Column_List">
        comment_id, user_id, work_id, parent_comment_id, in_comment_id, comment_floor, comment_text, approval_status, is_delete, time
    </sql>

    <!-- 新增评论 -->
    <insert id="insertComment" parameterType="top.playereg.pix_vision.pojo.commentsPojo.Comments" useGeneratedKeys="true" keyProperty="comment_id">
        INSERT INTO tb_comments (user_id, work_id, parent_comment_id, in_comment_id, comment_floor, comment_text, approval_status, is_delete, time)
        VALUES (#{user_id}, #{work_id}, #{parent_comment_id}, #{in_comment_id}, #{comment_floor}, #{comment_text}, #{approval_status}, 0, NOW())
    </insert>

    <!-- 根据作品 ID 查询评论列表 -->
    <select id="selectCommentsByWorkId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM tb_comments
        WHERE work_id = #{workId}
          AND is_delete = 0
        ORDER BY
            comment_floor ASC,
            <choose>
                <when test="orderBy == 'oldest'">
                    comment_id ASC
                </when>
                <otherwise>
                    comment_id DESC
                </otherwise>
            </choose>
    </select>

    <!-- 根据评论 ID 查询评论信息 -->
    <select id="selectCommentById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM tb_comments
        WHERE comment_id = #{commentId}
          AND is_delete = 0
    </select>

    <!-- 更新评论（用于更新 in_comment_id） -->
    <update id="updateById">
        UPDATE tb_comments
        SET in_comment_id = #{et.in_comment_id}
        WHERE comment_id = #{et.comment_id}
    </update>

    <!-- 批量删除评论 -->
    <update id="deleteComments">
        UPDATE tb_comments
        SET is_delete = #{isDelete}
        WHERE comment_id IN
        <foreach collection="commentIds" item="comment_id" open="(" separator="," close=")">
            #{comment_id}
        </foreach>
    </update>


</mapper>
