<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="top.playereg.pix_vision.mapper.WorksMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="top.playereg.pix_vision.pojo.Works">
        <id column="work_id" property="work_id"/>
        <result column="user_id" property="user_id"/>
        <result column="work_title" property="work_title"/>
        <result column="img_url" property="img_url"/>
        <result column="series_id" property="series_id"/>
        <result column="like_count" property="like_count"/>
        <result column="star_count" property="star_count"/>
        <result column="view_count" property="view_count"/>
        <result column="is_original_work" property="is_original_work"/>
        <result column="out_url" property="out_url"/>
        <result column="is_delete" property="is_delete"/>
        <result column="update_time" property="update_time"/>
        <result column="update_user" property="update_user"/>
        <result column="create_time" property="create_time"/>
        <result column="create_user" property="create_user"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        work_id
        , user_id, work_title, img_url, series_id, like_count, star_count, view_count, is_original_work, out_url, is_delete, update_time, update_user, create_time, create_user
    </sql>

    <!-- 分页查询首页作品列表（支持多条件查询，未删除，按创建时间倒序） -->
    <select id="selectHomepageWorks" resultMap="BaseResultMap">
        SELECT w.work_id,
               w.user_id,
               w.work_title,
               w.img_url,
               w.series_id,
               w.like_count,
               w.star_count,
               w.view_count,
               w.is_original_work,
               w.out_url,
               w.update_time,
               w.update_user,
               w.create_time,
               w.create_user
        FROM tb_works w
        LEFT JOIN tb_user u ON w.user_id = u.user_id
        WHERE w.is_delete = 0
        <if test="workTitle != null and workTitle != ''">
            AND w.work_title LIKE CONCAT('%', #{workTitle}, '%')
        </if>
        <if test="userId != null">
            AND w.user_id = #{userId}
        </if>
        <if test="username != null and username != ''">
            AND u.username LIKE CONCAT('%', #{username}, '%')
        </if>
        <if test="nickname != null and nickname != ''">
            AND u.nickname LIKE CONCAT('%', #{nickname}, '%')
        </if>
        <if test="isOriginal != null">
            AND w.is_original_work = #{isOriginal}
        </if>
        ORDER BY w.create_time DESC
    </select>

    <!-- 批量逻辑删除作品（SQL 层面验证用户权限） -->
    <update id="batchDeleteWorks">
        UPDATE tb_works
        SET is_delete = 1,
        update_time = NOW(),
        update_user = #{userId}
        WHERE user_id = #{userId}
        AND is_delete = 0
        AND work_id IN
        <foreach collection="workIds" item="workId" open="(" separator="," close=")">
            #{workId}
        </foreach>
    </update>

    <!-- 根据 ID 集合批量查询作品 -->
    <select id="selectBatchIds" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM tb_works
        WHERE work_id IN
        <foreach collection="coll" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <!-- 将指定系列的所有作品 series_id 置空（SQL 层面验证用户权限） -->
    <update id="clearSeriesIdBySeriesId">
        UPDATE tb_works
        SET series_id   = NULL,
            update_time = NOW(),
            update_user = #{userId}
        WHERE series_id = #{seriesId}
          AND user_id = #{userId}
          AND is_delete = 0
    </update>

    <!-- 根据系列 ID 查询所有作品 ID（用于删除系列内作品） -->
    <select id="selectWorkIdsBySeriesId" resultType="java.lang.Integer">
        SELECT work_id
        FROM tb_works
        WHERE series_id = #{seriesId}
          AND user_id = #{userId}
          AND is_delete = 0
    </select>

    <!-- 根据作品 ID 查询作品信息 -->
    <select id="selectWorkById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM tb_works
        WHERE work_id = #{workId}
    </select>

    <!-- 更新作品信息（SQL 层面验证用户权限，动态更新非空字段） -->
    <update id="updateWorkInfo">
        UPDATE tb_works
        <set>
            <if test="workTitle != null">
                work_title = #{workTitle},
            </if>
            <if test="imgUrl != null">
                img_url = #{imgUrl},
            </if>
            <if test="shouldUpdateSeries != null and shouldUpdateSeries">
                series_id = #{seriesId},
            </if>
            <if test="isOriginal != null">
                is_original_work = #{isOriginal},
            </if>
            <if test="outUrl != null">
                out_url = #{outUrl},
            </if>
            update_time = NOW(),
            update_user = #{userId}
        </set>
        WHERE work_id = #{workId}
          AND user_id = #{userId}
          AND is_delete = 0
    </update>

</mapper>
