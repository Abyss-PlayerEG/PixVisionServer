<!-- Pixie Vision 默认模板 -->
<!--
占位符说明：
{{logoUriLight}}: 浅色模式 logo Base64
{{logoUriDark}}: 深色模式 logo Base64
{{username}}：用户名
{{email_text}}：邮箱操作内容
{{code}}：验证码
{{year}}：当前年份
{{systemName}}：系统名称
-->
<!DOCTYPE html>
<html lang='zh-CN'>
<head>
  <meta charset='UTF-8'>
  <meta name='viewport' content='width=device-width, initial-scale=1.0'>
  <meta http-equiv='X-UA-Compatible' content='IE=edge'>
  <title>邮箱验证码</title>
  <style type='text/css'>
    body { margin: 0; padding: 0; min-width: 100%; background-color: #f4f6f9; -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table { border-spacing: 0; border-collapse: collapse; }
    img { border: 0; }
    .wrapper { width: 100%; table-layout: fixed; background-color: #f4f6f9; padding-bottom: 60px; }
    .main-container { background-color: #ffffff; margin: 0 auto; width: 100%; max-width: 520px; border-radius: 12px; overflow: hidden; box-shadow: 0 8px 20px rgba(0,0,0,0.06); }
    .header-bar { height: 6px; background-color: #4A90E2; }
    .logo-section { text-align: center; padding: 30px 30px 20px; background-color: #f8f9fa; border-bottom: 1px solid #e9ecef; }
    .logo-image { width: 80px; height: 80px; object-fit: contain; }
    .content-padding { padding: 40px 30px; }
    .code-box { background-color: #f0f7ff; border: 2px dashed #b3d4fc; border-radius: 8px; padding: 24px 10px; margin: 25px 0; text-align: center; }
    .code-text { font-family: 'Courier New', Courier, monospace; font-size: 36px; font-weight: 700; color: #2c3e50; letter-spacing: 10px; display: inline-block; }
    .footer-section { background-color: #fafbfc; border-top: 1px solid #eeeeee; padding: 25px 30px; text-align: center; }
    .text-secondary { color: #8898aa; font-size: 13px; line-height: 1.6; }
    .text-primary { color: #333333; font-size: 16px; line-height: 1.6; }
    h1 { margin: 0 0 15px; font-size: 24px; font-weight: 600; color: #1a202c; }
    
    /* 深色模式支持 */
    @media (prefers-color-scheme: dark) {
      body { background-color: #1a1a1a !important; }
      .wrapper { background-color: #1a1a1a !important; }
      .main-container { background-color: #2d2d2d !important; box-shadow: 0 8px 20px rgba(0,0,0,0.3) !important; }
      .logo-section { background-color: #333333 !important; border-bottom-color: #444444 !important; }
      .code-box { background-color: #3a3a3a !important; border-color: #555555 !important; }
      .code-text { color: #e0e0e0 !important; }
      .footer-section { background-color: #2a2a2a !important; border-top-color: #444444 !important; }
      .text-primary { color: #e0e0e0 !important; }
      .text-secondary { color: #a0a0a0 !important; }
      h1 { color: #ffffff !important; }
      
      /* 深色模式下隐藏浅色 logo，显示深色 logo */
      .logo-light { display: none !important; }
      .logo-dark { display: inline-block !important; }
    }
    
    /* 默认隐藏深色 logo */
    .logo-dark { display: none; }
  </style>
</head>
<body>
  <center class='wrapper'>
    <table width='100%'>
      <tr>
        <td align='center'>
          <!-- 主卡片 -->
          <div class='main-container'>
            <!-- 顶部品牌色条 -->
            <div class='header-bar'></div>
            
            <!-- Logo 区域 -->
            <div class='logo-section'>
              <!-- 浅色模式 logo -->
              <img src='{{logoUriLight}}' alt='Logo' class='logo-image logo-light' />
              <!-- 深色模式 logo -->
              <img src='{{logoUriDark}}' alt='Logo' class='logo-image logo-dark' />
            </div>
            
            <!-- 内容区域 -->
            <table width='100%'>
              <tr>
                <td class='content-padding'>
                  <h1>邮箱地址验证</h1>
                  <p class='text-primary'>您好！</p>
                  <p class='text-primary'>您正在对 {{systemName}} 账号：<strong style='color: #e67e22; text-shadow: 0 0 8px rgba(230, 126, 34, 0.3);'>{{username}}</strong> 进行操作。</p>
                  <p class='text-primary'>请使用下方的验证码完成账号 <strong style='color: #e67e22; text-shadow: 0 0 8px rgba(230, 126, 34, 0.3);'>{{email_text}}</strong> 操作。为了保障您的账号安全，请勿将验证码告知他人。</p>

                  <!-- 注册验证码提示 -->
                  <!-- 请使用下方的验证码完成账号注册验证操作。为了保障您的账号安全，请勿将验证码告知他人。-->

                  <!-- 登录验证码提示 -->
                  <!-- 请使用下方验证码完成账号登录验证操作。为了保障您的账号安全，请勿将验证码告知他人。-->

                  <!-- 修改密码验证码提示 -->
                  <!-- 请使用下方验证码完成修改密码操作。为了保障您的账号安全，请勿将验证码告知他人。-->
                  
                  <!-- 验证码核心区域 -->
                  <div class='code-box'>
                    <span class='code-text'>{{code}}</span>
                  </div>
                  
                  <!-- 提示信息 -->
                  <p style='margin: 0; text-align: center; font-size: 14px; color: #666666;'>
                    验证码有效期为 <strong style='color: #4A90E2;'>{{expireTime}}分钟</strong>，请尽快使用。
                  </p>
                </td>
              </tr>
            </table>
            
            <!-- 底部区域 -->
            <div class='footer-section'>
              <p class='text-secondary' style='margin: 0 0 10px;'>
                如果您没有请求此验证码，请忽略此邮件。
              </p>
              <p class='text-secondary' style='margin: 0;'>
                &copy; {{year}} {{systemName}}. All rights reserved.
              </p>
            </div>
          </div>
          
          <!-- 外部版权/退订链接 (可选) -->
          <p style='margin-top: 20px; font-size: 12px; color: #cbd5e0; text-align: center;'>
            此邮件由系统自动发送，请勿直接回复。
          </p>
        </td>
      </tr>
    </table>
  </center>
</body>
</html>